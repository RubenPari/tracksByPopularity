{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tracks-by-popularity-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "TracksByPopularity"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "your-secret-key-change-in-production-min-32-chars-long",
    "Issuer": "tracksByPopularity",
    "Audience": "tracksByPopularity",
    "ExpiryDays": 7
  },
  "MailtrapSettings": {
    "ApiKey": "",
    "InboxId": "",
    "FromEmail": "noreply@trackbypopularity.com",
    "FromName": "Tracks by Popularity",
    "ClientUrl": "http://localhost:5173"
  },
  "DatabaseSettings": {
    "ConnectionString": "Server=localhost;Port=3306;Database=tracksbypopularity;User=root;Password=password;"
  }
}
